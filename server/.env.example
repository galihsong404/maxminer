# Database
DATABASE_URL="postgresql://user:password@localhost:5432/maxminer?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/maxminer?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Security
JWT_SECRET="generate-a-long-random-string-here"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_BOT_NAME="MaxMinerBot"

# Infrastructure
PORT=3000
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# Ad Network (Monetag S2S Secret)
MONETAG_SECRET="your-monetag-s2s-secret-key"

# BSC Payout Config
BSC_RPC_URL="https://data-seed-prebsc-1-s1.binance.org:8545"
OWNER_PRIVATE_KEY="your-private-key-here"
TOKEN_CONTRACT_ADDRESS="your-contract-address-here"
ENABLE_PAYOUTS="false"
